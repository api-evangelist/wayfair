{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wayfair/refs/heads/main/json-schema/wayfair-token-response-schema.json",
  "title": "TokenResponse",
  "description": "TokenResponse schema from Wayfair Supplier API",
  "type": "object",
  "properties": {
    "access_token": {
      "type": "string",
      "description": "JWT bearer token for subsequent API requests.",
      "example": "eyJhbGciOiJSUzI1NiJ9.example.token"
    },
    "token_type": {
      "type": "string",
      "description": "Token type, always \"Bearer\".",
      "example": "Bearer"
    },
    "expires_in": {
      "type": "integer",
      "description": "Token expiration time in seconds.",
      "example": 3600
    }
  }
}